# Application Settings
APP_NAME=rag-multi-agent-system
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Authentication
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Vector Database - Pinecone
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=rag-embeddings

# Vector Database - Weaviate
WEAVIATE_URL=https://your-cluster.weaviate.network
WEAVIATE_API_KEY=your_weaviate_api_key
WEAVIATE_CLASS_NAME=Document

# Vector Store Selection
VECTOR_STORE=pinecone  # Options: pinecone, weaviate

# Kubernetes
K8S_NAMESPACE=rag-system
K8S_CLUSTER_NAME=production-cluster

# Docker Registry
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-username
DOCKER_IMAGE_PREFIX=rag-system

# Monitoring
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
LOG_FORMAT=json

# Resource Limits
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT_SECONDS=30
```


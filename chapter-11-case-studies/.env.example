# API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# Vector Database
VECTOR_STORE=pinecone  # or weaviate

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=case-studies

# Weaviate Configuration
WEAVIATE_URL=https://your-cluster.weaviate.network
WEAVIATE_API_KEY=your_weaviate_key
WEAVIATE_CLASS_NAME=Document

# Application Settings
ENVIRONMENT=development  # development, staging, production
LOG_LEVEL=INFO
DEBUG=false

# Healthcare Case Study
HEALTHCARE_EHR_ENDPOINT=https://ehr-system.example.com/fhir
HEALTHCARE_EHR_API_KEY=your_ehr_key
HEALTHCARE_ENCRYPTION_KEY=your_encryption_key_32_chars_min
HEALTHCARE_AUDIT_DB_URL=postgresql://user:pass@localhost/healthcare_audit

# Enterprise Case Study
ENTERPRISE_SHAREPOINT_URL=https://company.sharepoint.com
ENTERPRISE_SHAREPOINT_CLIENT_ID=your_client_id
ENTERPRISE_SHAREPOINT_CLIENT_SECRET=your_client_secret
ENTERPRISE_CONFLUENCE_URL=https://company.atlassian.net
ENTERPRISE_CONFLUENCE_API_TOKEN=your_confluence_token
ENTERPRISE_SLACK_BOT_TOKEN=xoxb-your-slack-token
ENTERPRISE_AD_ENDPOINT=ldap://ad.company.com

# Education Case Study
EDUCATION_LMS_URL=https://lms.school.edu
EDUCATION_LMS_API_KEY=your_lms_key
EDUCATION_STUDENT_DB_URL=postgresql://user:pass@localhost/education
EDUCATION_ANALYTICS_ENABLED=true

# DevOps Case Study
DEVOPS_PROMETHEUS_URL=http://prometheus:9090
DEVOPS_ELASTICSEARCH_URL=http://elasticsearch:9200
DEVOPS_KUBERNETES_CONFIG=~/.kube/config
DEVOPS_PAGERDUTY_API_KEY=your_pagerduty_key
DEVOPS_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Security
JWT_SECRET_KEY=your_jwt_secret_key_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Database (Common)
DATABASE_URL=postgresql://user:pass@localhost/case_studies

# Redis (Caching)
REDIS_URL=redis://localhost:6379/0

# Monitoring
PROMETHEUS_ENABLED=true
METRICS_PORT=9090
```
